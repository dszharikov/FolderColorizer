<Window x:Class="FolderColorizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folder Colorizer"
        Width="650"
        Height="610"
        MinWidth="560"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FB"
        FontFamily="{StaticResource AppFont}">
    <Window.Resources>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#27324A" />
            <Setter Property="BorderBrush" Value="#D8DEEA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EEF2F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width" Value="124" />
            <Setter Property="Height" Value="76" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ColorBorder"
                                Background="{TemplateBinding Background}"
                                RenderTransformOrigin="0.5,0.5"
                                CornerRadius="13">
                            <Grid>
                                <Rectangle Margin="1"
                                           RadiusX="12"
                                           RadiusY="12"
                                           Stroke="#28FFFFFF"
                                           StrokeThickness="1" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Width="28"
                                          Height="22"
                                          Margin="0,0,0,5"
                                          Stretch="Fill"
                                          Fill="#EEFFFFFF"
                                          Data="M1,5 C1,3 2,2 4,2 L11,2 L14,5 L24,5 C26,5 27,6 27,8 L27,19 C27,21 26,22 24,22 L4,22 C2,22 1,21 1,19 Z" />
                                    <ContentPresenter HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColorBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.035" ScaleY="1.035" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ColorBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15"
                                                          ShadowDepth="3"
                                                          Opacity="0.24" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ColorBorder" Property="Opacity" Value="0.78" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="34,27,34,25"
                Background="#172033"
                CornerRadius="0,0,22,22">
            <StackPanel>
                <TextBlock FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           Text="Folder Colorizer" />
                <TextBlock Margin="0,7,0,0"
                           FontSize="14"
                           Foreground="#B9C5DA"
                           Text="Give important folders a color you can spot instantly." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="34,26,34,28">
                <TextBlock FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#59657A"
                           Text="FOLDER" />
                <Grid Margin="0,8,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="13,11"
                            Background="White"
                            BorderBrush="#D8DEEA"
                            BorderThickness="1"
                            CornerRadius="9">
                        <TextBox x:Name="FolderPathTextBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="14"
                                 Foreground="#27324A"
                                 VerticalContentAlignment="Center" />
                    </Border>
                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            Click="BrowseButton_Click"
                            Content="Browse…"
                            Style="{StaticResource SecondaryButton}" />
                </Grid>

                <TextBlock FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#59657A"
                           Text="CHOOSE A COLOR" />
                <ItemsControl x:Name="PaletteItems" Margin="-6,8,-6,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Background="{Binding Hex}"
                                    Click="ColorButton_Click"
                                    Content="{Binding DisplayName}"
                                    Style="{StaticResource ColorButton}"
                                    Tag="{Binding Id}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid>
                    <Button HorizontalAlignment="Left"
                            Click="ResetButton_Click"
                            Content="Restore default icon"
                            Style="{StaticResource SecondaryButton}" />
                    <TextBlock x:Name="StatusText"
                               Margin="18,0,0,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#16865B"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
